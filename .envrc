# shellcheck shell=bash
# Use nix flake for development environment
use flake

# Project-specific environment variables
export HOMEBASE_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/homebase"
export HOMEBASE_PORT="8000"

# Ensure config directory exists
mkdir -p "$HOMEBASE_CONFIG_DIR/dashboards"

# Create example dashboard if none exists
if [ ! -f "$HOMEBASE_CONFIG_DIR/dashboards/default.yaml" ]; then
  echo "Creating example dashboard at $HOMEBASE_CONFIG_DIR/dashboards/default.yaml"
  cp -n "$(dirname "$0")/examples/default.yaml" "$HOMEBASE_CONFIG_DIR/dashboards/" 2>/dev/null || true
fi
