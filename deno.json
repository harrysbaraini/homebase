{
  "lock": false,
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check **/*.ts && deno check **/*.tsx",
    "dev": "deno run -A --watch=static/,routes/,src/ dev.ts",
    "build": "deno run -A dev.ts build",
    "preview": "deno run -A main.ts",
    "compile": "deno task build && deno compile --include static/ --include _fresh/ --include deno.json -A -o homebase main.ts",
    "test": "deno test -A tests/",
    "service": "deno run -A service.ts"
  },
  "imports": {
    "$fresh/": "https://deno.land/x/fresh@1.7.3/",
    "preact": "https://esm.sh/preact@10.24.3",
    "preact/": "https://esm.sh/preact@10.24.3/",
    "@preact/signals": "https://esm.sh/@preact/signals@1.3.0?deps=preact@10.24.3",
    "@preact/signals-core": "https://esm.sh/@preact/signals-core@1.8.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.5",
    "@std/async": "jsr:@std/async@^1.0.8",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/fs": "jsr:@std/fs@^1.0.6",
    "zod": "https://esm.sh/zod@3.23.8",
    "marked": "https://esm.sh/marked@15.0.4",
    "tailwindcss": "npm:tailwindcss@3.4.17",
    "tailwindcss/": "npm:/tailwindcss@3.4.17/",
    "tailwindcss/plugin": "npm:/tailwindcss@3.4.17/plugin.js",
    "@/": "./src/"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "dom.asynciterable", "deno.ns"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "nodeModulesDir": "auto",
  "exclude": ["**/_fresh/*"]
}
